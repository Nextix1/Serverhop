local HttpService = game:GetService("HttpService")
local TeleportService = game:GetService("TeleportService")
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

local PlaceId = game.PlaceId
local JobId = game.JobId

local TargetIsland = "island5"
local TargetFolder = "Slapples"
local TargetItem = "Glove"
local ScriptUrl = "https://raw.githubusercontent.com/Nextix1/Serverhop/refs/heads/main/Slapple/Farm"

local TeleportQueue = queue_on_teleport or (syn and syn.queue_on_teleport) or (fluxus and fluxus.queue_on_teleport)

if TeleportQueue and ScriptUrl ~= "https://raw.githubusercontent.com/Nextix1/Serverhop/refs/heads/main/Slapple/Farm" then
    TeleportQueue("loadstring(game:HttpGet('" .. ScriptUrl .. "'))()")
end

if not game:IsLoaded() then
    game.Loaded:Wait()
end

repeat task.wait() until LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")

local Character = LocalPlayer.Character
local RootPart = Character.HumanoidRootPart

if not Character:FindFirstChild("entered") then
    repeat task.wait()
        firetouchinterest(RootPart, workspace.Lobby.Teleport1, 0)
        firetouchinterest(RootPart, workspace.Lobby.Teleport1, 1)
    until Character:FindFirstChild("entered")
end

local ItemContainer = workspace.Arena[TargetIsland][TargetFolder]

for _, obj in ipairs(ItemContainer:GetDescendants()) do
    if obj.Name == TargetItem and obj:FindFirstChildWhichIsA("TouchTransmitter") then
        firetouchinterest(RootPart, obj, 0)
        firetouchinterest(RootPart, obj, 1)
    end
end

local ApiUrl = "https://games.roblox.com/v1/games/" .. PlaceId .. "/servers/Public?sortOrder=Asc&limit=100"
local ServerData = HttpService:JSONDecode(game:HttpGetAsync(ApiUrl)).data

local TargetServerId = nil
local LowestPlayers = math.huge

for _, server in ipairs(ServerData) do
    if type(server) == "table" and server.id ~= JobId then
        local currentPlayers = tonumber(server.playing)
        local maxPlayers = tonumber(server.maxPlayers)
        
        if currentPlayers and maxPlayers and currentPlayers < maxPlayers then
            if currentPlayers < LowestPlayers then
                LowestPlayers = currentPlayers
                TargetServerId = server.id
            end
        end
    end
end

if TargetServerId then
    TeleportService:TeleportToPlaceInstance(PlaceId, TargetServerId, LocalPlayer)
else
    error("No available servers found")
end
